# ── Anthropic (Claude KI) ─────────────────────────────────────────────────────
# Holen auf: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-DEIN-KEY-HIER

# ── Twilio (WhatsApp Versand) ─────────────────────────────────────────────────
# Holen auf: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sicherheit (optional) ─────────────────────────────────────────────────────
# Twilio-Signatur auf eingehenden Webhook-Requests prüfen.
# In Produktion auf 1 setzen, damit nur echte Twilio-Requests durchkommen.
TWILIO_VALIDATE_SIGNATURE=0
